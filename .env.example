# ===========================================
# TeamMatching 部署环境变量配置
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ===========================================

# Docker镜像配置
DEPLOY_IMAGE=teammatching:latest

# 应用端口
APP_PORT=8080

# 应用环境 (test/prod)
APP_ENVIRONMENT=prod

# ===========================================
# 数据库配置（必填）
# ===========================================
# 主机须为 compose 服务名 mysql（勿用 127.0.0.1）。库名与 init_db.sql 一致：team_matching
DB_URL=jdbc:mysql://mysql:3306/team_matching?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
DB_USERNAME=root
# 若用 root 连接，必须与下方 MYSQL_ROOT_PASSWORD 完全一致（改 .env 后旧数据卷不会自动改密码）
DB_PASSWORD=root123456

# 与 DB_PASSWORD 保持一致（mysql 容器首次初始化后密码写在数据卷里，仅改此处不重建卷则应用仍会 Access denied）
MYSQL_ROOT_PASSWORD=root123456

MYSQL_DATABASE=team_matching

# MySQL外部访问端口（可选，生产环境建议不暴露）
MYSQL_EXTERNAL_PORT=3306

# ===========================================
# Redis配置
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DATABASE=0
REDIS_TIMEOUT=2000ms

# Redis外部访问端口（可选，生产环境建议不暴露）
REDIS_EXTERNAL_PORT=6379

# ===========================================
# 邮件配置（可选）
# ===========================================
MAIL_ENABLED=false
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=

# ===========================================
# 阿里云OSS配置（必填，用于文件上传）
# ===========================================
OSS_ENABLED=true
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET_NAME=team-matching
OSS_CUSTOM_DOMAIN=
OSS_FILE_PREFIX=team-matching/

# ===========================================
# 微信小程序配置（可选）
# ===========================================
WECHAT_MINIAPP_APPID=
WECHAT_MINIAPP_SECRET=
WECHAT_MINIAPP_ENABLED=false

# ===========================================
# 短信配置（可选）
# ===========================================
SMS_ENABLED=false
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=TeamMatch
SMS_TEMPLATE_CODE=

# ===========================================
# JVM参数（可选）
# ===========================================
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC
