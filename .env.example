# ===========================================
# TeamMatching 部署环境变量配置
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ===========================================

# Docker镜像配置
DEPLOY_IMAGE=teammatching:latest

# 应用端口
APP_PORT=8080

# 应用环境 (test/prod)
APP_ENVIRONMENT=prod

# ===========================================
# 数据库配置（必填）
# ===========================================
DB_URL=jdbc:mysql://mysql:3306/teammatching?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
DB_USERNAME=teammatching
DB_PASSWORD=your_strong_password_here

# MySQL Root密码
MYSQL_ROOT_PASSWORD=root123456

# MySQL数据库名称
MYSQL_DATABASE=teammatching

# MySQL外部访问端口（可选，生产环境建议不暴露）
MYSQL_EXTERNAL_PORT=3306

# ===========================================
# Redis配置
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DATABASE=0
REDIS_TIMEOUT=2000ms

# Redis外部访问端口（可选，生产环境建议不暴露）
REDIS_EXTERNAL_PORT=6379

# ===========================================
# 邮件配置（可选）
# ===========================================
MAIL_ENABLED=false
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=

# ===========================================
# 阿里云OSS配置（必填，用于文件上传）
# ===========================================
OSS_ENABLED=true
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET_NAME=team-matching
OSS_CUSTOM_DOMAIN=
OSS_FILE_PREFIX=team-matching/

# ===========================================
# 微信小程序配置（可选）
# ===========================================
WECHAT_MINIAPP_APPID=
WECHAT_MINIAPP_SECRET=
WECHAT_MINIAPP_ENABLED=false

# ===========================================
# 短信配置（可选）
# ===========================================
SMS_ENABLED=false
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=TeamMatch
SMS_TEMPLATE_CODE=

# ===========================================
# JVM参数（可选）
# ===========================================
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC
